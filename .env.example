BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username   # without @
ADMIN_IDS=123456789,987654321
DB_PATH=./shop.db

# SePay PG hosted checkout (Vietnam VND)
SEPAY_MERCHANT_ID=your_merchant_id
SEPAY_SECRET_KEY=your_secret_key
SEPAY_PG_ENV=sandbox             # or: production

# NTPAY USDT crypto payment
NTPAY_BASE_URL=https://your-ntpay-domain.com
NTPAY_MERCHANT_ID=your_ntpay_merchant_id
NTPAY_API_KEY=your_ntpay_api_key

# Public URL of this server (reachable by SePay IPN and NTPAY callback)
SERVER_URL=http://your-vps-ip:3000

# HTTP server port
WEBHOOK_PORT=3000

# Currency conversion (used to auto-compute USDT price from VND)
VND_TO_USD_RATE=25000   # 1 USD = 25,000 VND — update when rate changes

# Order settings
ORDER_PREFIX=ORDER
ORDER_EXPIRE_MINUTES=30
